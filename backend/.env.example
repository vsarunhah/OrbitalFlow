# --- Database (use one of the following) ---
# Local (Docker Compose):
# DATABASE_URL=postgresql://jobtracker:jobtracker@localhost:5432/jobtracker
# Supabase: Project Settings → Database → Connection string → URI (use "Direct" for long-lived app + worker).
#           Append ?sslmode=require if not already in the URL. Example:
# DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL=postgresql://jobtracker:jobtracker@localhost:5432/jobtracker

REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_ENCRYPTION_KEY=
# Google OAuth (get from https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/email-accounts/gmail/oauth-callback
# Sync / worker settings
SYNC_POLL_INTERVAL_SECONDS=300
SYNC_LOOKBACK_MINUTES=30
RQ_JOB_TIMEOUT=600
RQ_RETRY_MAX=3
RQ_RETRY_DELAY=60
